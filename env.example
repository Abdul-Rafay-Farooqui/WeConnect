# ============================================================
# ChatWave — Environment Variables
# Copy this file to .env.local and fill in your credentials
# NEVER commit .env.local to git
# ============================================================

# ──────────────────────────────────────────────────────────
# SUPABASE
# Get these from: https://supabase.com/dashboard
# Your Project > Settings > API
# ──────────────────────────────────────────────────────────

# Your Supabase project URL (looks like: https://xxxxxxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=https://tvexpctqgpvjnjidffyd.supabase.co

# Supabase anonymous/public key (safe to expose in browser)
# Found under: Settings > API > Project API keys > anon / public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR2ZXhwY3RxZ3B2am5qaWRmZnlkIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzU3MjA3NjAsImV4cCI6MjA5MTI5Njc2MH0.JlwLVkTUTzVgQyi46VHneZo8YM0rn4VfUTgQZuVVw6A

# Supabase service role key (NEVER expose to browser — server only)
# Found under: Settings > API > Project API keys > service_role
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InR2ZXhwY3RxZ3B2am5qaWRmZnlkIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NTcyMDc2MCwiZXhwIjoyMDkxMjk2NzYwfQ.ZlKNj938pM35b25RdfgVjGGz6H_vLRK_4E49vaoBaQk

# ──────────────────────────────────────────────────────────
# AGORA (Voice & Video Calls)
# Get these from: https://console.agora.io
# Create a project > Get App ID
# ──────────────────────────────────────────────────────────

# Your Agora App ID (safe to expose — used in browser SDK)
NEXT_PUBLIC_AGORA_APP_ID=2923c9cd6d21447a8dfc62e653f8573e

# Agora App Certificate (server-side only — for token generation)
# Found in Agora Console > Your Project > App Certificate
# Leave blank during development if using test mode (no token required)
AGORA_APP_CERTIFICATE=5c75a9c0858343f6baa1dc84d1ba362a

# ──────────────────────────────────────────────────────────
# OPENROUTER (AI Chatbox)
# Get your key from: https://openrouter.ai/keys
# ──────────────────────────────────────────────────────────

# OpenRouter API key (server-side only — NEVER expose to browser)
OPENROUTER_API_KEY=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

# ──────────────────────────────────────────────────────────
# APP CONFIG
# ──────────────────────────────────────────────────────────

# Your app's public URL (used for OpenRouter HTTP-Referer header)
# Development: http://localhost:3000
# Production: https://yourdomain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# App name displayed in UI
NEXT_PUBLIC_APP_NAME=ChatWave

# ──────────────────────────────────────────────────────────
# OPTIONAL: Only needed for production Agora token server
# ──────────────────────────────────────────────────────────

# Token expiry in seconds (default: 3600 = 1 hour)
AGORA_TOKEN_EXPIRY=3600

